# Optional Google Maps settings for src/components/Location.tsx

# Preferred: paste the iframe src generated by Google Maps embed share.
# Example: https://www.google.com/maps?....
VITE_GOOGLE_MAPS_EMBED_URL=

# Optional: external link target for the "Open in Google Maps" button.
VITE_GOOGLE_MAPS_OPEN_URL=https://maps.google.com/?q=Galissea+Galissas+Syros

# Optional: review listing / leave-review target. Falls back to VITE_GOOGLE_MAPS_OPEN_URL.
VITE_GOOGLE_REVIEWS_URL=

# Optional: direct write-review link. Defaults to the current place id.
VITE_GOOGLE_WRITE_REVIEW_URL=

# Optional: Google rating summary shown in the minimal reviews section.
VITE_GOOGLE_RATING_VALUE=4.7
VITE_GOOGLE_RATING_COUNT=48

# Alternative (only if using Google Maps Embed API):
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_PLACE_QUERY=Galissea Galissas Syros
